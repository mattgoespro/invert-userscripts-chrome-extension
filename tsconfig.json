{
  "extends": "./tsconfig.base.json",
  "include": [
    "packages/renderer/src/**/*.ts",
    "packages/renderer/src/**/*.tsx",
    "packages/runtime/src/**/*.ts",
    "packages/shared/src/**/*.ts",
    "packages/monaco/src/**/*.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "lib": ["es2020", "dom", "dom.iterable", "es2023.array"],
    "types": ["chrome", "react", "react-dom"],
    "paths": {
      "@/*": ["./packages/renderer/src/*"],
      "@shared/*": ["./packages/shared/src/*"],
      "@packages/monaco": ["./packages/monaco/src/index.ts"],
      "@monaco/*": ["./packages/monaco/src/*"],
      "monaco-editor-core": ["./node_modules/monaco-editor"]
    }
  }
}
