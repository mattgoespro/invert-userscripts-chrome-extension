{
  "[chatagent]": {
    "editor.defaultFormatter": "darkriszty.markdown-table-prettify",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "[instructions]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "css.customData": [".vscode/tailwindcss.data.json"],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.fixAll.markdownlint": "always",
    "source.fixAll.prettier": "always",
    "source.removeUnusedImports": "never"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontFamily": "'Reddit Mono', 'Fira Code', 'Ubuntu Mono', monospace",
  "editor.fontSize": 12,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.letterSpacing": -0.5,
  "editor.linkedEditing": true,
  "editor.minimap.autohide": true,
  "editor.minimap.maxColumn": 150,
  "editor.minimap.scale": 3,
  "editor.minimap.showSlider": "mouseover",
  "editor.rename.enablePreview": true,
  "eslint.codeActionsOnSave.mode": "problems",
  "eslint.enable": true,
  "eslint.format.enable": false,
  "eslint.probe": ["typescript", "typescriptreact", "html"],
  "eslint.useFlatConfig": true,
  "eslint.validate": ["typescript", "typescriptreact", "html"],
  "explorer.confirmDragAndDrop": false,
  "files.associations": {
    ".eslintignore": "ignore"
  },
  "files.eol": "\n",
  "files.exclude": {
    "**/.buildcache/**": true,
    "**/.git/**": true,
    "**/node_modules/**": true
  },
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/.buildcache/**": true,
    "**/.git/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true
  },
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "gitProjectManager.baseProjectsFolders": ["%USERPROFILE%\\Desktop\\Code"],
  "gitProjectManager.openInNewWindow": true,
  "markdown.extension.completion.enabled": true,
  "markdown.extension.italic.indicator": "_",
  "markdown.preview.fontSize": 11,
  "markdown.validate.enabled": true,
  "prettier.configPath": "prettier.config.mjs",
  "prettier.requireConfig": true,
  "search.exclude": {
    "**/*.json": true,
    "**/*.md": true,
    "**/.vscode/**": true,
    "**/dist/**": true,
    "**/examples/**": true
  },
  "tailwindCSS.includeLanguages": {
    "typescriptreact": "html"
  },
  "terminal.integrated.automationProfile.windows": {
    "args": ["-l"],
    "color": "terminal.ansiMagenta",
    "env": {
      "PATH": "${workspaceFolder}\\node_modules\\.bin;${env:PATH}",
      "TIMING": "1"
    },
    "path": "C:\\Program Files\\Git\\bin\\bash.exe"
  },
  "terminal.integrated.defaultProfile.windows": "bash-node",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.fontFamily": "'Ubuntu Mono', monospace",
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.mouseWheelScrollSensitivity": 3,
  "terminal.integrated.profiles.windows": {
    "bash-node": {
      "args": ["-l"],
      "color": "terminal.ansiCyan",
      "env": {
        "PATH": "${workspaceFolder}\\node_modules\\.bin;${env:PATH}",
        "TIMING": "1"
      },
      "icon": "terminal-bash",
      "overrideName": true,
      "path": "C:\\Program Files\\Git\\bin\\bash.exe"
    }
  },
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.stickyScroll.enabled": true,
  "typescript.format.enable": false,
  "typescript.preferences.importModuleSpecifier": "shortest",
  "typescript.preferences.renameMatchingJsxTags": true,
  "typescript.preferences.useAliasesForRenames": false,
  "typescript.tsc.autoDetect": "off",
  "typescript.tsdk": "node_modules\\typescript\\lib",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "vsicons.dontShowNewVersionMessage": true,
  "workbench.activityBar.orientation": "vertical",
  "workbench.colorTheme": "Default Dark+",
  "workbench.editor.closeOnFileDelete": true,
  "workbench.iconTheme": "vscode-icons",
  "workbench.settings.enableNaturalLanguageSearch": true,
  "workbench.tree.indent": 10
}
