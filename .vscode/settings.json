{
  "[chatagent]": {
    "editor.defaultFormatter": "darkriszty.markdown-table-prettify",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "[instructions]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "chat.agent.maxRequests": 1000,
  "chat.agent.thinking.collapsedTools": "withThinking",
  "chat.agent.thinkingStyle": "collapsedPreview",
  "chat.artifacts.enabled": true,
  "chat.implicitContext.enabled": {
    "agent": "always",
    "ask": "always"
  },
  "chat.planAgent.defaultModel": "Claude Sonnet 4.6 (copilot)",
  "chat.sessionSync.enabled": true,
  "chat.tools.terminal.autoApprove": {
    "/.*/": true
  },
  "chat.tools.terminal.ignoreDefaultAutoApproveRules": true,
  "chat.tools.urls.autoApprove": {
    "http://*": true,
    "https://*": true
  },
  "chat.viewSessions.orientation": "sideBySide",
  "css.customData": [".vscode/tailwindcss.data.json"],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always",
    "source.fixAll.markdownlint": "always",
    "source.fixAll.prettier": "always",
    "source.removeUnusedImports": "never"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontFamily": "'Fira Code', 'Source Code Pro', 'Ubuntu Mono', monospace, 'Droid Sans Mono', 'Courier New'",
  "editor.fontSize": 11,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.letterSpacing": -0.5,
  "editor.lineHeight": 1.4,
  "editor.linkedEditing": true,
  "editor.minimap.autohide": "mouseover",
  "editor.minimap.maxColumn": 150,
  "editor.minimap.scale": 3,
  "editor.minimap.showSlider": "mouseover",
  "editor.rename.enablePreview": true,
  "eslint.codeActionsOnSave.mode": "problems",
  "eslint.enable": true,
  "eslint.format.enable": false,
  "eslint.probe": ["typescript", "typescriptreact", "html"],
  "eslint.useFlatConfig": true,
  "eslint.validate": ["typescript", "typescriptreact", "html"],
  "explorer.confirmDragAndDrop": false,
  "files.associations": {
    ".eslintignore": "ignore"
  },
  "files.eol": "\n",
  "files.exclude": {
    "**/.buildcache/**": true,
    "**/.git/**": true,
    "**/node_modules/**": true
  },
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/.buildcache/**": true,
    "**/.git/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true
  },
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "gitProjectManager.baseProjectsFolders": ["%USERPROFILE%\\Desktop\\Code"],
  "gitProjectManager.openInNewWindow": true,
  "github.copilot.chat.agent.autoFix": true,
  "github.copilot.chat.completionsFetcher": "electron-fetch",
  "github.copilot.chat.exploreAgent.model": "Claude Sonnet 4.6 (copilot)",
  "github.copilot.chat.githubMcpServer.enabled": true,
  "github.copilot.chat.implementAgent.model": "Claude Sonnet 4.6 (copilot)",
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.includeDocumentation": true,
  "github.copilot.chat.localIndex.enabled": true,
  "github.copilot.chat.switchAgent.enabled": true,
  "github.copilot.enable": {
    "*": true
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "js/ts.format.enabled": false,
  "js/ts.preferences.importModuleSpecifier": "shortest",
  "js/ts.preferences.renameMatchingJsxTags": true,
  "js/ts.preferences.useAliasesForRenames": false,
  "js/ts.tsc.autoDetect": "off",
  "js/ts.tsdk.path": "node_modules\\typescript\\lib",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "json.schemaDownload.trustedDomains": {
    "*": true
  },
  "markdown.extension.completion.enabled": true,
  "markdown.extension.italic.indicator": "_",
  "markdown.preview.fontSize": 11,
  "markdown.validate.enabled": true,
  "npm-outdated.majorUpdateProtection": false,
  "prettier.configPath": "prettier.config.mjs",
  "prettier.requireConfig": true,
  "search.exclude": {
    "**/*.json": true,
    "**/*.md": true,
    "**/.vscode/**": true,
    "**/dist/**": true,
    "**/examples/**": true
  },
  "tailwindCSS.includeLanguages": {
    "typescriptreact": "html"
  },
  "terminal.integrated.automationProfile.windows": {
    "args": ["-l"],
    "color": "terminal.ansiMagenta",
    "env": {
      "PATH": "${workspaceFolder}\\node_modules\\.bin;${env:PATH}",
      "TIMING": "1"
    },
    "path": "C:\\Program Files\\Git\\bin\\bash.exe"
  },
  "terminal.integrated.defaultProfile.windows": "bash-node",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.fontFamily": "Hack, Fira Code, Ubuntu Mono, monospace",
  "terminal.integrated.fontSize": 11,
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.mouseWheelScrollSensitivity": 3,
  "terminal.integrated.profiles.windows": {
    "bash-node": {
      "args": ["-l"],
      "color": "terminal.ansiCyan",
      "env": {
        "PATH": "${workspaceFolder}\\node_modules\\.bin;${env:PATH}",
        "TIMING": "1"
      },
      "icon": "terminal-bash",
      "overrideName": true,
      "path": "C:\\Program Files\\Git\\bin\\bash.exe"
    }
  },
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.stickyScroll.enabled": true,
  "vsicons.dontShowNewVersionMessage": true,
  "workbench.browser.enableChatTools": true,
  "workbench.colorTheme": "Dark Modern",
  "workbench.editor.closeOnFileDelete": true,
  "workbench.iconTheme": "vscode-icons",
  "workbench.tree.indent": 10
}
