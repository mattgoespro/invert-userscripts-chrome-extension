{
  "[chatagent]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "[instructions]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "[scss]": {
    "editor.defaultFormatter": "sibiraj-s.vscode-scss-formatter",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true
  },
  "chat.agent.maxRequests": 1000,
  "chat.autopilot.enabled": true,
  "chat.planAgent.defaultModel": "Claude Opus 4.6 (fast mode) (Preview) (claude-code)",
  "chat.tools.terminal.autoApprove": {
    "/.*/": true
  },
  "chat.tools.terminal.autoReplyToPrompts": true,
  "chat.tools.terminal.ignoreDefaultAutoApproveRules": true,
  "chat.tools.urls.autoApprove": {
    "https://*.github.com": true,
    "https://*.npmjs.com": true,
    "https://github.com": true,
    "https://raw.githubusercontent.com": true,
    "https://shiki.style": true,
    "https://www.npmjs.com": true
  },
  "chat.viewSessions.orientation": "stacked",
  "editor.codeActionsOnSave": {
    "source.addMissingImports.ts": "always",
    "source.fixAll.eslint": "always",
    "source.removeUnusedImports": "never"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.rename.enablePreview": true,
  "eslint.enable": true,
  "eslint.format.enable": false,
  "eslint.probe": ["typescript", "typescriptreact", "html"],
  "eslint.useFlatConfig": true,
  "eslint.validate": ["typescript", "typescriptreact", "html"],
  "explorer.confirmDragAndDrop": false,
  "files.associations": {
    ".eslintignore": "ignore"
  },
  "files.eol": "\n",
  "files.exclude": {
    "**/.buildcache/**": true,
    "**/.git/**": true,
    "**/node_modules/**": true
  },
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/.buildcache/**": true,
    "**/.git/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true
  },
  "github.copilot.chat.agent.autoFix": true,
  "github.copilot.chat.completionsFetcher": "electron-fetch",
  "github.copilot.chat.copilotMemory.enabled": true,
  "github.copilot.chat.githubMcpServer.enabled": true,
  "github.copilot.chat.implementAgent.model": "Claude Opus 4.6",
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.includeDocumentation": true,
  "github.copilot.chat.responsesApiReasoningEffort": "high",
  "github.copilot.chat.switchAgent.enabled": true,
  "github.copilot.enable": {
    "markdown": true,
    "plaintext": true,
    "scminput": true
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "inlineChat.enableV2": true,
  "js/ts.format.enabled": false,
  "js/ts.preferences.importModuleSpecifier": "shortest",
  "js/ts.tsc.autoDetect": "off",
  "js/ts.tsdk.path": "node_modules\\typescript\\lib",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "json.schemaDownload.trustedDomains": {
    "*": true
  },
  "markdown.extension.completion.enabled": true,
  "markdown.extension.italic.indicator": "_",
  "markdown.preview.fontSize": 11,
  "markdown.validate.enabled": true,
  "npm-outdated.majorUpdateProtection": false,
  "prettier.configPath": "prettier.config.mjs",
  "prettier.requireConfig": true,
  "scss.format.enable": false,
  "scss.lint.duplicateProperties": "error",
  "scss.lint.emptyRules": "warning",
  "scss.lint.propertyIgnoredDueToDisplay": "warning",
  "scss.lint.unknownAtRules": "warning",
  "scss.lint.unknownProperties": "warning",
  "scss.lint.zeroUnits": "warning",
  "scss.showErrors": true,
  "scss.validate": true,
  "scssFormatter.printWidth": 100,
  "scssFormatter.trailingComma": "es5",
  "search.exclude": {
    "**/*.json": true,
    "**/*.md": true,
    "**/.vscode/**": true,
    "**/dist/**": true
  },
  "terminal.integrated.automationProfile.windows": {
    "args": ["-l"],
    "color": "terminal.ansiMagenta",
    "env": {
      "PATH": "${workspaceFolder}\\node_modules\\.bin;${env:PATH}",
      "TIMING": "1"
    },
    "path": "C:\\Program Files\\Git\\bin\\bash.exe"
  },
  "terminal.integrated.defaultProfile.windows": "bash-node",
  "terminal.integrated.fontFamily": "Hack, Fira Code, Ubuntu Mono, monospace",
  "terminal.integrated.fontSize": 11,
  "terminal.integrated.profiles.windows": {
    "bash-node": {
      "args": ["-l"],
      "color": "terminal.ansiCyan",
      "env": {
        "PATH": "${workspaceFolder}\\node_modules\\.bin;${env:PATH}",
        "TIMING": "1"
      },
      "icon": "terminal-bash",
      "overrideName": true,
      "path": "C:\\Program Files\\Git\\bin\\bash.exe"
    }
  },
  "terminal.integrated.shellIntegration.enabled": true,
  "vsicons.dontShowNewVersionMessage": true,
  "workbench.browser.enableChatTools": true,
  "workbench.iconTheme": "vscode-icons"
}
