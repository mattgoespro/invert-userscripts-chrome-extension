{
  "extends": "../tsconfig.base.json",
  "include": ["**/*.ts"],
  "exclude": ["report"],
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2020", "dom"],
    "types": ["@playwright/test", "node", "chrome"],
    "noEmit": true,
    "strict": false,
    "noImplicitAny": true,
    "paths": {
      "@shared/*": ["../packages/shared/src/*"]
    }
  }
}
